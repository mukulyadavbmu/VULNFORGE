# Google Gemini API Key (Free tier: https://makersuite.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Backend server port
PORT=4000

# PostgreSQL Database Connection String (Neon, Supabase, etc.)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# API key for backend authentication (generate a random string)
VULNFORGE_API_KEY=your_random_api_key_here

# Frontend origin for CORS
FRONTEND_ORIGIN=https://your-frontend-domain.vercel.app

# Backend Public URL (for OAST callbacks)
BACKEND_URL=https://your-backend-app.onrender.com

# Upstash Redis URL (Required for distributed scanning workers)
REDIS_URL="rediss://default:password@host:port"
USE_DISTRIBUTED_QUEUE=true
